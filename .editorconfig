# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

# 2 space indentation for common web files
[*.{js,jsx,ts,tsx,json,html,css,scss,yml,yaml}]
indent_style = space
indent_size = 2
max_line_length = 80
# Markdown files might need trailing whitespace for line breaks
[*.md]
trim_trailing_whitespace = false
